# Copy to .env.local and fill in. Never commit real secrets.

# --- Auth.js v5 / Google OAuth (U3) ---
# Generate with: npx auth secret
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Comma-separated allowlist of the two adult Google emails (U3).
# NOTE: CONTEXT seeds @gmail.com addresses — set the real two emails here.
ALLOWED_EMAILS=hendrik.buender@gmail.com,jennifer.buender@gmail.com

# --- Database: Neon Postgres (U2) ---
# Pooled connection string for runtime queries (PgBouncer endpoint).
DATABASE_URL=
# Direct/unpooled connection string — migrations only.
DATABASE_URL_UNPOOLED=

# --- OpenAI (U7 vision import, U9 starter set, U14 arrangement) ---
OPENAI_API_KEY=
